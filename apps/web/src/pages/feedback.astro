---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FeedbackForm from '../components/FeedbackForm';

const title = 'Give Feedback — Dashboard New Brunswick';
const description =
  'Spotted an error or have a suggestion? Send feedback to the Dashboard New Brunswick team.';
---

<Base {title} {description}>
  <Nav />

  <main>
    <section class="px-4 py-16">
      <div class="mx-auto max-w-2xl">
        <a
          href="/"
          class="mb-8 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700"
        >
          <span aria-hidden="true">←</span> Back to Dashboard
        </a>

        <div class="mb-2 flex items-center gap-3">
          <div class="h-6 w-1 rounded bg-blue-600"></div>
          <h1 class="text-2xl font-bold text-gray-900">Give Feedback</h1>
        </div>
        <p class="mb-8 text-sm text-gray-500">
          We use public government data and aim to be accurate. If something looks wrong, tell us —
          we read every submission.
        </p>

        <FeedbackForm client:load />
      </div>
    </section>
  </main>

  <Footer />
</Base>
