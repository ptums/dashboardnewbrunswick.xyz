---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroScore from '../components/HeroScore';
import VerdictSection from '../components/VerdictSection';
import SafetySection from '../components/SafetySection';
import SchoolsSection from '../components/SchoolsSection';
import CostSection from '../components/CostSection';
import JobsSection from '../components/JobsSection';
import NeighborhoodSection from '../components/NeighborhoodSection';
import AirQualitySection from '../components/AirQualitySection';
import DemographicsSection from '../components/DemographicsSection';
import FeedbackBanner from '../components/FeedbackBanner';
import FeedbackForm from '../components/FeedbackForm';

const title = 'Is New Brunswick a good place to live? | Dashboard New Brunswick';
const description =
  'Data-driven answers about living in New Brunswick, NJ — crime, schools, cost of living, jobs, and more. Sourced from public government data.';
---

<Base {title} {description}>
  <Nav />

  <main>
    <HeroScore client:load />

    <SafetySection client:load />

    <SchoolsSection client:load />

    <CostSection client:load />

    <JobsSection client:load />

    <NeighborhoodSection client:load />

    <AirQualitySection client:load />

    <DemographicsSection client:load />

    <VerdictSection data={null} client:load />

    <FeedbackBanner client:load />

    <section id="feedback-form" class="border-t border-gray-100 bg-white px-4 py-16">
      <div class="mx-auto max-w-2xl">
        <div class="mb-2 flex items-center gap-3">
          <div class="h-6 w-1 rounded bg-blue-600"></div>
          <h2 class="text-2xl font-bold text-gray-900">Leave Feedback</h2>
        </div>
        <p class="mb-6 text-sm text-gray-500">
          All fields except Message are optional. We read every submission.
        </p>
        <FeedbackForm client:load />
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  import { track } from '../lib/posthog';
  track('dashboard_viewed');
</script>
